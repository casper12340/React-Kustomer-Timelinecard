/* CustomAlert.css */

.modal-backdrop {
  position: fixed;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  overflow-y: auto; /* Add this to allow scrolling if content overflows */
}

.modal-content {
  background: white;
  padding: 20px;
  border-radius: 8px;
  box-shadow: 0 4px 8px rgba(0, 0, 0, 0.2);
  text-align: center;
  max-width: 400px;
  width: 80%;
  position: absolute; /* Change position to absolute */
  top: 700px; /* Set top to 50px */
  left: 50%;
  transform: translateX(-50%); /* Center horizontally */
}

.modal-content h2 {
  margin: 0 0 10px;
  color: #333;
}

.modal-content p {
  margin: 10px 0;
  color: #555;
}

.modal-content button {
  padding: 10px 20px;
  background: #E3A4C0;
  color: black;
  font-weight: bold;
  border: none;
  border-radius: 5px;
  cursor: pointer;
  margin-top: 10px;
}

.modal-content button:hover {
  background: #d186a0;
}
