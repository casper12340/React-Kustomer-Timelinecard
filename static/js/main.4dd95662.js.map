import React, { useEffect } from 'react';

export default function AddNote(props) {
    const { data2, setReturnData } = props;
    const kobject = data2?.huts?.customContext?.kobject;
    const orderID = kobject?.custom?.incrementIdStr;

    useEffect(() => {
        if (!orderID) {
            console.warn("orderID is not available");
            return;
        }

        const myHeaders = new Headers();
        myHeaders.append("Authorization", "Bearer XhPeDPsNuaHf7pw2GAWNBA2HmKNuGQyRZ1ZDpm1hd0649e8c");
        myHeaders.append("Accept", "application/json");



    const raw = JSON.stringify({
        "note": props.noteID,
        "actor": "string",
        "is_visible_for_customer": false
    });

    const requestOptions = {
        method: "POST",
        headers: myHeaders,
        body: raw,
        redirect: "follow"
    };

    fetch('https://api-v2.returnless.com/2023-01/request-orders/returnorder_v3VBMABlgxENGtn1JLXlxKs9w/notes', requestOptions)
    .then(response => {
        if (!response.ok) {
            throw new Error(`HTTP error! Status: ${response.status}`);
        }
        return response.json();
    })
    .then(result => {
        if (result?.data?.length > 0) {
            setReturnData(result.data[0]);
        } else {
            console.log(result)
            setReturnData("No return data found");
        }
    })
    .catch(error => {
        setReturnData("Er is iets fout gegaan");
        console.error("Fetch error: ", error);
    });
}, [props.noteID, props.id]);

return null;
}